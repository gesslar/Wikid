{
  "name": "@gesslar/wikid",
  "description": "If Salt'n'Pepa wrote a MediaWiki authentication package in Node.js",
  "author": {
    "name": "gesslar",
    "url": "https://gesslar.dev"
  },
  "version": "2.3.0",
  "license": "Unlicense",
  "homepage": "https://github.com/gesslar/wikid#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesslar/wikid.git"
  },
  "keywords": [
    "mediawiki",
    "wiki",
    "media",
    "utilities",
    "esm",
    "push",
    "it",
    "real",
    "good"
  ],
  "type": "module",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/types/lib/Wikid.d.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "UNLICENSE.txt"
  ],
  "scripts": {
    "dev": "node src/index.js",
    "test": "node tests/unit/Wikid.test.js",
    "types": "node -e \"require('fs').rmSync('src/types',{recursive:true,force:true});\" && tsc -p tsconfig.types.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "submit": "npm publish --access public --//registry.npmjs.org/:_authToken=\"${NPM_ACCESS_TOKEN}\"",
    "update": "npm up --latest --recursive",
    "pr": "gt submit -p --ai",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "dependencies": {
    "@gesslar/toolkit": "^5.0.1"
  },
  "devDependencies": {
    "@gesslar/uglier": "^2.0.0",
    "eslint": "^10.0.0",
    "typescript": "^6.0.2"
  }
}
